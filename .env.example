# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit it.

# --- Twilio (SMS) ----------------------------------------------------------
# Rotate your token at https://console.twilio.com/ if these have ever been
# exposed. Leave blank to disable SMS entirely.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Demo mode -------------------------------------------------------------
# When DEMO_MODE=true, /api/sos still records the event and the dashboard
# shows it, but no actual SMS goes out. Use this during the live demo so
# judges' phones don't get blasted.
DEMO_MODE=true

# --- Admin dashboard auth --------------------------------------------------
# HTTP Basic auth credentials for the admin dashboard and PATCH endpoints.
ADMIN_USER=admin
ADMIN_PASS=admin

# --- Server ----------------------------------------------------------------
PORT=8787

# --- ML risk model ---------------------------------------------------------
# Path to the trained model file (joblib). Relative to backend/.
RISK_MODEL_PATH=data/risk_model.joblib
